# ── 예시 전용: 실제 키·비밀번호는 넣지 마세요. 팀원은 각자 로컬에 `.env` 를 만듭니다. ──
# 공공데이터포털·Google API 키 — 실제 값은 절대 Git에 올리지 마세요.
# 사용법: 이 파일을 복사해 `.env`로 저장한 뒤 값을 채웁니다.
#   cp .env.example .env   (Windows: copy .env.example .env)
# `.env`, `.env.local`, `.env.*` 는 `.gitignore` 로 제외됩니다. 예시만 커밋합니다.

WEATHER_API_KEY=your_weather_api_key_here
TOUR_API_KEY=your_tour_api_key_here
AIR_KOREA_API_KEY=your_air_korea_api_key_here
GOOGLE_PLACES_KEY=your_google_places_api_key_here

# 한국관광공사 스토리텔링 DB CSV(선택). 없거나 깨지면 스토리 보강 비활성.
# 레포에 포함된 공사 파일명(프로젝트 루트 기준). 다른 경로면 STORYTELLING_CSV_PATH만 바꾸면 됩니다.
STORYTELLING_CSV_PATH=한국관광공사_관광 스토리텔링 DB 정보_20160906.csv

# 전국(또는 시·도) 도시관광 식당 공공 API(선택). 미설정 시 Google Places만 사용.
CITYTOUR_RESTAURANT_API_KEY=your_citytour_restaurant_api_key_here
CITYTOUR_RESTAURANT_BASE_URL=your_citytour_restaurant_api_base_url_here
# BASE 뒤에 붙일 경로(없으면 BASE URL만 호출)
# CITYTOUR_RESTAURANT_PATH=
# 쿼리스트링 키 이름(공공데이터 관행: serviceKey)
# CITYTOUR_RESTAURANT_KEY_PARAM=serviceKey
# 위도·경도를 쿼리로 보낼지(기본 true; API 스펙에 맞게 false 가능)
# CITYTOUR_RESTAURANT_SEND_COORDS=true
# 추가 쿼리(JSON 한 줄). 예: {"MobileApp":"App","MobileOS":"ETC","_type":"json"}
# CITYTOUR_RESTAURANT_EXTRA_PARAMS=

# 에어코리아 전용 키가 없을 때만: 다른 공공데이터 키 이름(선택)
# PUBLIC_DATA_SERVICE_KEY=

# 서비스 루트 URL (비밀이 아님). 운영 기본값과 같으면 생략 가능합니다.
WEATHER_BASE_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0
TOUR_BASE_URL=https://apis.data.go.kr/B551011/KorService2
AIR_KOREA_BASE_URL=https://apis.data.go.kr/B552584/ArpltnInforInqireSvc
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1/places:searchNearby

# Google 사진 URL 조합용 (기본: 아래와 동일하면 생략 가능)
# GOOGLE_PLACES_V1_ROOT=https://places.googleapis.com/v1

# 전체 URL을 직접 쓰고 싶을 때만 설정 (위 BASE보다 우선)
# WEATHER_FORECAST_URL=https://apis.data.go.kr/1360000/VilageFcstInfoService_2.0/getVilageFcst
# AIR_KOREA_FORECAST_URL=https://apis.data.go.kr/B552584/ArpltnInforInqireSvc/getCtprvnRltmMesureDnsty

# UI: 비우면 자동( frontend/dist/index.html 이 있으면 Vite, 없으면 static 의 레거시 index.html)
# 강제로 예전 static 만 쓰려면: FRONTEND_UI=static
# FRONTEND_UI=
PORT=8000
DEBUG=true

# --- 선택: Ollama(로컬) — "오늘 코스" 한 덩어리 문구만 생성. 랭킹에는 사용하지 않음 ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# --- 코스 단위 재정렬(학습) — /api/recommend 후보 순서. 번들 없으면 규칙 순서 유지(model_used=false).
# COURSE_RERANK_MODEL_DIR=

# --- 시나리오 학습 next_scene 모델 (선택, 약지도·합성 데이터 전제) — /api/course 실험용 ---
# pip install -r requirements-ml.txt 후 학습: python scripts/train_next_scene_model.py --write-demo-data
# 홈페이지 랭킹(/api/recommend)에는 사용되지 않음. /api/course 도 기본은 규칙만 —
# 모델 추론은 API 쿼리 ml_next_scene_assist=true 이고 아래가 켜져 있을 때만.
# NEXT_SCENE_MODEL=true
# NEXT_SCENE_MODEL_DIR=data/scenario_ml/artifacts/next_scene_model
# NEXT_SCENE_MODEL_MIN_CONFIDENCE=0.38
